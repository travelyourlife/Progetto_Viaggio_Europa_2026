flowchart TD
    subgraph FONTI["📡 Fonti Dati GPS"]
        A["🌐 Browser<br/>watchPosition()"]
        B["📱 GPSLogger<br/>(nativo Android)"]
        C["🛣️ OSRM API<br/>(stima stradale)"]
        D["✏️ Inserimento<br/>Manuale km"]
    end

    subgraph STORAGE["☁️ Storage Intermedio"]
        E["📂 Google Drive<br/>GPSLogger for Android/"]
        F["🔥 Firebase RTDB<br/>tracks/{data}/points"]
    end

    subgraph PROCESSING["⚙️ Elaborazione"]
        G["🔄 Drive Sync<br/>(OAuth2 + query)"]
        H["📊 Merge + Dedup<br/>(finestra 30s)"]
        I["🧮 Calcolo km<br/>(Haversine)"]
    end

    subgraph OUTPUT["📊 Output Utente"]
        J["🗺️ Mappa Leaflet<br/>(traccia + marker)"]
        K["📈 Statistiche<br/>(km, tappe, %)"]
        L["📋 Riepilogo<br/>Giornaliero"]
    end

    A -->|"ogni ~5s"| F
    B -->|".gpx ogni 30s"| E
    E -->|"sync ogni 60min"| G
    G -->|"parse GPX"| H
    C -->|"geometria percorso"| H
    H -->|"punti unificati"| F
    D -->|"odometerKm"| F
    F --> I
    I --> J
    I --> K
    I --> L

    style FONTI fill:#e3f2fd,stroke:#1565c0
    style STORAGE fill:#fff3e0,stroke:#e65100
    style PROCESSING fill:#f3e5f5,stroke:#6a1b9a
    style OUTPUT fill:#e8f5e9,stroke:#2e7d32
