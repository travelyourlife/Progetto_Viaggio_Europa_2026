rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: check if user is an owner
    function isOwner() {
      return request.auth != null && (
        request.auth.uid == 'RxlVlsfeaEeSwFUVYbKQujEsbBo1' ||
        request.auth.uid == 'Mh8BOeFPnFe7WObcsUoP6wyRgPw1'
      );
    }

    // Helper: check if user is approved (via Realtime DB not available in Storage rules,
    // so we rely on auth != null + path structure)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: max file size
    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    // Helper: allowed image types
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // Helper: allowed audio types
    function isAudio() {
      return request.resource.contentType.matches('audio/.*');
    }

    // Diary uploads: diary/{familyId}/{dayKey}/{filename}
    // Owner can upload diary post media (images, audio)
    match /diary/{familyId}/{dayKey}/{filename} {
      allow read: if isAuthenticated();
      allow write: if isOwner() && (isImage() || isAudio()) && maxSize(10);
    }

    // v4.01: Comment photos: diary/{familyId}/{postKey}/comments/{filename}
    // Any authenticated user can upload comment photos (max 5MB)
    match /diary/{familyId}/{postKey}/comments/{filename} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isImage() && maxSize(5);
    }

    // Chat uploads: chat/{filename}
    match /chat/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isImage() || isAudio()) && maxSize(10);
    }

    // v4.02: Postcard photos: postcards/{familyId}/{filename}
    // Any authenticated user can send postcard photos (max 5MB, images only)
    match /postcards/{familyId}/{filename} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isImage() && maxSize(5);
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
